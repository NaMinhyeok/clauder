{
  "name": "clauder",
  "version": "0.1.0",
  "description": "Grow your coding companion — RPG + Tamagotchi gamification for Claude Code",
  "hooks": [
    {
      "event": "PostToolUse",
      "type": "command",
      "command": "npx tsx \"${CLAUDE_PLUGIN_ROOT}/src/cli.ts\" post-tool-use \"${CLAUDE_PLUGIN_DATA}\"",
      "timeout": 5000
    },
    {
      "event": "SessionStart",
      "type": "command",
      "command": "npx tsx \"${CLAUDE_PLUGIN_ROOT}/src/cli.ts\" session-start \"${CLAUDE_PLUGIN_DATA}\"",
      "timeout": 5000
    },
    {
      "event": "SessionEnd",
      "type": "command",
      "command": "npx tsx \"${CLAUDE_PLUGIN_ROOT}/src/cli.ts\" session-end \"${CLAUDE_PLUGIN_DATA}\"",
      "timeout": 5000
    }
  ],
  "commands": [
    "commands/clauder.md",
    "commands/clauder-stats.md",
    "commands/clauder-hall.md",
    "commands/clauder-achieve.md",
    "commands/clauder-retire.md"
  ]
}
